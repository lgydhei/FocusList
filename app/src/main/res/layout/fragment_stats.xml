<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp">

        <!-- 第一行：今日 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:minHeight="82dp"
                    android:padding="12dp">

                    <TextView android:id="@+id/textTodayMinutes" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_today_minutes" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:minHeight="82dp"
                    android:padding="12dp">

                    <TextView android:id="@+id/textTodayCount" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_today_count" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- 第二行：累计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:minHeight="82dp"
                    android:padding="12dp">

                    <TextView android:id="@+id/textTotalMinutes" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_total_minutes" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:minHeight="82dp"
                    android:padding="12dp">

                    <TextView android:id="@+id/textTotalCount" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_total_count" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- 连续天数 + 待办数量 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:minHeight="82dp"
                    android:padding="12dp">

                    <TextView android:id="@+id/textStreakDays" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_streak_days" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:minHeight="82dp"
                    android:padding="12dp">

                    <TextView android:id="@+id/textPendingCount" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_pending" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- 7天专注图表 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutDailyChart"
            style="@style/Widget.Material3.CardView.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_7day_chart"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <View android:id="@+id/barDay1"
                            android:layout_width="24dp" android:layout_height="16dp"
                            android:background="@drawable/bg_tag" />
                        <TextView android:id="@+id/textBarDay1"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <View android:id="@+id/barDay2"
                            android:layout_width="24dp" android:layout_height="16dp"
                            android:background="@drawable/bg_tag" />
                        <TextView android:id="@+id/textBarDay2"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <View android:id="@+id/barDay3"
                            android:layout_width="24dp" android:layout_height="16dp"
                            android:background="@drawable/bg_tag" />
                        <TextView android:id="@+id/textBarDay3"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <View android:id="@+id/barDay4"
                            android:layout_width="24dp" android:layout_height="16dp"
                            android:background="@drawable/bg_tag" />
                        <TextView android:id="@+id/textBarDay4"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <View android:id="@+id/barDay5"
                            android:layout_width="24dp" android:layout_height="16dp"
                            android:background="@drawable/bg_tag" />
                        <TextView android:id="@+id/textBarDay5"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <View android:id="@+id/barDay6"
                            android:layout_width="24dp" android:layout_height="16dp"
                            android:background="@drawable/bg_tag" />
                        <TextView android:id="@+id/textBarDay6"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <View android:id="@+id/barDay7"
                            android:layout_width="24dp" android:layout_height="16dp"
                            android:background="@drawable/bg_tag" />
                        <TextView android:id="@+id/textBarDay7"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 分类统计 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutCategoryStats"
            style="@style/Widget.Material3.CardView.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_category_stats"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/textCategoryStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 内容提供器查询按钮 -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Material3.CardView.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnProviderDemo"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/provider_demo"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_tasks"
                    app:iconSize="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 最近记录 -->
        <TextView
            style="@style/ScreenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:text="@string/recent_sessions" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSessions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/textNoSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:background="@drawable/bg_panel"
            android:layout_marginTop="8dp"
            android:padding="24dp"
            android:text="@string/no_session"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
